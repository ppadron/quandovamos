<%# locals: (event:, guest:) %>
<div class="space-y-8">
  <% event_slots_grouped_by_week_monday_local(event).sort.each do |monday, week_slots| %>
    <div class="calendar-card">
      <div class="calendar-card-body space-y-4">
        <% sunday = monday + 6 %>
        <h3 class="card-title text-lg">
          <%= t("calendar.week_range_title",
                start: monday.strftime("%d/%m/%Y"),
                end: sunday.strftime("%d/%m/%Y")) %>
        </h3>
        <div class="space-y-4 md:hidden">
          <% (0..6).each_slice(1) do |day_indexes| %>
            <div class="calendar-scroll">
              <table class="table table-xs sm:table-sm table-bordered w-full">
                <thead>
                  <tr>
                    <th class="calendar-sticky-head calendar-sticky-corner w-14"><%= t("calendar.hour_column") %></th>
                    <% day_indexes.each do |d| %>
                      <% day_date = monday + d %>
                      <th class="calendar-sticky-head text-center">
                        <div class="font-semibold"><%= calendar_weekday_abbrs[d] %></div>
                        <div class="text-xs font-normal opacity-80"><%= day_date.strftime("%d/%m") %></div>
                      </th>
                    <% end %>
                  </tr>
                </thead>
                <tbody>
                  <% timed_grid_hours_for_week_slots(week_slots).each do |hour| %>
                    <tr>
                      <td class="bg-base-200 font-mono text-xs whitespace-nowrap"><%= sprintf("%02d:00", hour) %></td>
                      <% day_indexes.each do |d| %>
                        <% day_date = monday + d %>
                        <% cell_time = Time.zone.local(day_date.year, day_date.month, day_date.day, hour, 0, 0) %>
                        <% slot = week_slots.find { |s| s.starts_at.to_i == cell_time.to_i } %>
                        <% if slot %>
                          <% selected = guest.available_for?(slot) %>
                          <% past_slot = timed_slot_in_past?(slot) %>
                          <td class="<%= past_slot ? "bg-base-200/50 p-1 text-center" : "bg-primary/5 p-1 text-center" %>">
                            <% if past_slot %>
                              <%= hidden_field_tag "availability[#{slot.id}]", selected ? "1" : "0" %>
                              <label class="flex min-h-[3rem] cursor-not-allowed items-center justify-center rounded-xl border border-base-300 bg-base-200/60 opacity-55">
                                <%= check_box_tag "availability_disabled_#{slot.id}", "1", selected, class: "checkbox checkbox-primary pointer-events-none", disabled: true %>
                              </label>
                            <% else %>
                              <%= hidden_field_tag "availability[#{slot.id}]", "0" %>
                              <label class="flex min-h-[3rem] cursor-pointer items-center justify-center rounded-xl border border-dashed border-primary/30 bg-base-100/80 transition-colors hover:bg-base-100">
                                <%= check_box_tag "availability[#{slot.id}]", "1", selected, class: "checkbox checkbox-primary" %>
                              </label>
                            <% end %>
                          </td>
                        <% else %>
                          <td class="bg-base-200/40 p-0"></td>
                        <% end %>
                      <% end %>
                    </tr>
                  <% end %>
                </tbody>
              </table>
            </div>
          <% end %>
        </div>
        <div class="hidden calendar-scroll lg:block">
          <table class="table table-xs sm:table-sm table-bordered w-full min-w-[640px]">
            <thead>
              <tr>
                <th class="calendar-sticky-head calendar-sticky-corner w-14"><%= t("calendar.hour_column") %></th>
                <% 7.times do |d| %>
                  <% day_date = monday + d %>
                  <th class="calendar-sticky-head text-center">
                    <div class="font-semibold"><%= calendar_weekday_abbrs[d] %></div>
                    <div class="text-xs font-normal opacity-80"><%= day_date.strftime("%d/%m") %></div>
                  </th>
                <% end %>
              </tr>
            </thead>
            <tbody>
              <% timed_grid_hours_for_week_slots(week_slots).each do |hour| %>
                <tr>
                  <td class="bg-base-200 font-mono text-xs whitespace-nowrap"><%= sprintf("%02d:00", hour) %></td>
                  <% 7.times do |d| %>
                    <% day_date = monday + d %>
                    <% cell_time = Time.zone.local(day_date.year, day_date.month, day_date.day, hour, 0, 0) %>
                    <% slot = week_slots.find { |s| s.starts_at.to_i == cell_time.to_i } %>
                    <% if slot %>
                      <% selected = guest.available_for?(slot) %>
                      <% past_slot = timed_slot_in_past?(slot) %>
                      <td class="<%= past_slot ? "bg-base-200/50 p-1 text-center" : "bg-primary/5 p-1 text-center" %>">
                        <% if past_slot %>
                          <%= hidden_field_tag "availability[#{slot.id}]", selected ? "1" : "0" %>
                          <label class="flex min-h-[3rem] cursor-not-allowed items-center justify-center rounded-xl border border-base-300 bg-base-200/60 opacity-55">
                            <%= check_box_tag "availability_disabled_#{slot.id}", "1", selected, class: "checkbox checkbox-primary pointer-events-none", disabled: true %>
                          </label>
                        <% else %>
                          <%= hidden_field_tag "availability[#{slot.id}]", "0" %>
                          <label class="flex min-h-[3rem] cursor-pointer items-center justify-center rounded-xl border border-dashed border-primary/30 bg-base-100/80 transition-colors hover:bg-base-100">
                            <%= check_box_tag "availability[#{slot.id}]", "1", selected, class: "checkbox checkbox-primary" %>
                          </label>
                        <% end %>
                      </td>
                    <% else %>
                      <td class="bg-base-200/40 p-0"></td>
                    <% end %>
                  <% end %>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
        <div class="hidden space-y-4 md:block lg:hidden">
          <% (0..6).each_slice(3) do |day_indexes| %>
            <div class="calendar-scroll">
              <table class="table table-xs sm:table-sm table-bordered w-full">
                <thead>
                  <tr>
                    <th class="calendar-sticky-head calendar-sticky-corner w-14"><%= t("calendar.hour_column") %></th>
                    <% day_indexes.each do |d| %>
                      <% day_date = monday + d %>
                      <th class="calendar-sticky-head text-center">
                        <div class="font-semibold"><%= calendar_weekday_abbrs[d] %></div>
                        <div class="text-xs font-normal opacity-80"><%= day_date.strftime("%d/%m") %></div>
                      </th>
                    <% end %>
                  </tr>
                </thead>
                <tbody>
                  <% timed_grid_hours_for_week_slots(week_slots).each do |hour| %>
                    <tr>
                      <td class="bg-base-200 font-mono text-xs whitespace-nowrap"><%= sprintf("%02d:00", hour) %></td>
                      <% day_indexes.each do |d| %>
                        <% day_date = monday + d %>
                        <% cell_time = Time.zone.local(day_date.year, day_date.month, day_date.day, hour, 0, 0) %>
                        <% slot = week_slots.find { |s| s.starts_at.to_i == cell_time.to_i } %>
                        <% if slot %>
                          <% selected = guest.available_for?(slot) %>
                          <% past_slot = timed_slot_in_past?(slot) %>
                          <td class="<%= past_slot ? "bg-base-200/50 p-1 text-center" : "bg-primary/5 p-1 text-center" %>">
                            <% if past_slot %>
                              <%= hidden_field_tag "availability[#{slot.id}]", selected ? "1" : "0" %>
                              <label class="flex min-h-[3rem] cursor-not-allowed items-center justify-center rounded-xl border border-base-300 bg-base-200/60 opacity-55">
                                <%= check_box_tag "availability_disabled_#{slot.id}", "1", selected, class: "checkbox checkbox-primary pointer-events-none", disabled: true %>
                              </label>
                            <% else %>
                              <%= hidden_field_tag "availability[#{slot.id}]", "0" %>
                              <label class="flex min-h-[3rem] cursor-pointer items-center justify-center rounded-xl border border-dashed border-primary/30 bg-base-100/80 transition-colors hover:bg-base-100">
                                <%= check_box_tag "availability[#{slot.id}]", "1", selected, class: "checkbox checkbox-primary" %>
                              </label>
                            <% end %>
                          </td>
                        <% else %>
                          <td class="bg-base-200/40 p-0"></td>
                        <% end %>
                      <% end %>
                    </tr>
                  <% end %>
                </tbody>
              </table>
            </div>
          <% end %>
        </div>
      </div>
    </div>
  <% end %>
</div>

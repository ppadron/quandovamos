<%# locals: (event:, availability_names_by_slot_id:, unanimous_slot_id_set:) %>
<% slots_by_date = event_slots_indexed_by_local_date(event) %>
<div class="space-y-8">
  <% months_covering_event_slots(event).each do |month_start| %>
    <div class="calendar-card">
      <div class="calendar-card-body space-y-4">
        <h3 class="card-title text-lg">
          <%= "#{I18n.t("date.month_names")[month_start.month]} de #{month_start.year}" %>
        </h3>
        <div class="grid grid-cols-7 gap-1 text-center text-xs font-semibold text-base-content/60">
          <% calendar_weekday_abbrs.each do |w| %>
            <div><%= w %></div>
          <% end %>
        </div>
        <div class="grid grid-cols-7 gap-1">
          <% calendar_day_cells_for_month(month_start.year, month_start.month).each do |cell_date| %>
            <% if cell_date.nil? %>
              <div class="min-h-[5rem]"></div>
            <% else %>
              <% slot = slots_by_date[cell_date] %>
              <% if slot %>
                <% names = availability_names_by_slot_id[slot.id] || [] %>
                <% unanimous = unanimous_slot_id_set.include?(slot.id) %>
                <div class="relative flex min-h-[5.5rem] flex-col gap-1 rounded-2xl border border-primary/25 bg-primary/8 p-2 shadow-sm">
                  <% if unanimous %>
                    <span class="absolute right-1 top-1 flex h-6 w-6 items-center justify-center rounded-full bg-success text-sm font-bold leading-none text-success-content shadow-sm" title="<%= t("organizer.unanimous.title") %>">✓</span>
                  <% end %>
                  <span class="pr-7 text-center text-xs font-semibold leading-none"><%= cell_date.day %></span>
                  <div class="flex min-h-0 flex-1 flex-col justify-end text-left">
                    <% if names.any? %>
                      <ul class="max-h-24 space-y-0.5 overflow-y-auto text-[10px] leading-tight text-base-content/90">
                        <% names.each do |name| %>
                          <li class="break-words" title="<%= name %>"><%= name %></li>
                        <% end %>
                      </ul>
                    <% else %>
                      <p class="text-[10px] text-base-content/45"><%= t("organizer.availability_calendar.no_responses") %></p>
                    <% end %>
                  </div>
                </div>
              <% else %>
                <div class="flex min-h-[5.5rem] items-start justify-center rounded-2xl bg-base-200/45 pt-1.5 text-xs text-base-content/35">
                  <%= cell_date.day %>
                </div>
              <% end %>
            <% end %>
          <% end %>
        </div>
      </div>
    </div>
  <% end %>
</div>
